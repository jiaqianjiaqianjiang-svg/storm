    "import torch\n",
    "\n",
    "print(\"CUDA可用：\", torch.cuda.is_available())\n",
    "print(\"显卡名称：\", torch.cuda.get_device_name(0))\n",
    "\n",
    "# 实测GPU运算\n",
    "a = torch.randn(4096, 4096).cuda()\n",
    "b = torch.matmul(a, a)\n",
    "print(\"GPU运算完成\")"
   ]
